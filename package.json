{
  "name": "linguaflow",
  "version": "1.0.0",
  "description": "WhatsApp customer service center with real-time translation",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:server:dev\" \"npm:client:dev\"",
    "server:dev": "tsx watch src/server/index.ts",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build && cd .. && tsc",
    "start": "node dist/server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.3",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
